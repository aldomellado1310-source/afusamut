# ─── Firebase ─────────────────────────────────────────────────────────────────
# Copia este archivo a .env.local y completa los valores desde:
# Firebase Console → Configuración del proyecto → Aplicaciones web → Config SDK
#
# Sin estas variables el portal funciona en modo demo (sin persistencia).

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
