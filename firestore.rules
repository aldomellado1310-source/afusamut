rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()       { return request.auth != null; }
    function userData()     { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data; }
    function hasUserDoc()   { return isAuth() && exists(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function isActivo()     { return hasUserDoc() && userData().activo == true; }
    function isDirectorio() { return isActivo() && userData().rol in ['directorio','superadmin']; }
    function isSuperadmin() {
      return isActivo()
        && userData().rol == 'superadmin'
        && request.auth.token.email.matches('.*@micorriza\\.bio$');
    }
    function isOwner(uid)   { return isAuth() && request.auth.uid == uid; }
    function emailToken()   { return request.auth.token.email.lower(); }
    // El rol superadmin es EXCLUSIVO de cuentas @micorriza.bio
    function rolValido(data) {
      return data.rol != 'superadmin'
        || data.email.matches('.*@micorriza\\.bio$');
    }

    match /users/{uid} {
      // Socios solo leen su propio doc; el directorio lista todos
      allow get:  if isOwner(uid) || isDirectorio();
      allow list: if isDirectorio();
      // Inscribir socios: el directorio solo puede crear con rol 'socio'
      allow create: if isDirectorio()
        && request.resource.data.rol == 'socio';
      // Solo el superadmin crea con cualquier rol (superadmin solo @micorriza.bio)
      allow create: if isSuperadmin() && rolValido(request.resource.data);
      // El directorio edita datos básicos pero NO puede tocar rol ni activo
      allow update: if isDirectorio()
        && !request.resource.data.diff(resource.data).affectedKeys()
             .hasAny(['rol', 'activo']);
      // Cambio de rol y activar/desactivar: SOLO superadmin
      allow update: if isSuperadmin() && rolValido(request.resource.data);
      // Renuncia y reincorporación: el directorio registra bajas del gremio.
      // 'activo' debe ser coherente con 'estadoSocio' (renunciado → false,
      // activo → true); desactivar arbitrario sigue siendo del superadmin.
      allow update: if isDirectorio()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['estadoSocio', 'fechaRenuncia', 'motivoRenuncia', 'fechaReincorporacion', 'activo'])
        && request.resource.data.estadoSocio in ['activo', 'renunciado']
        && request.resource.data.activo == (request.resource.data.estadoSocio == 'activo');
      // Bootstrap del primer superadmin: una cuenta @micorriza.bio se crea a sí misma
      allow create: if isOwner(uid)
        && request.auth.token.email.matches('.*@micorriza\\.bio$')
        && request.resource.data.rol == 'superadmin'
        && request.resource.data.email == request.auth.token.email;
      // Un pre-inscrito reclama su ficha al primer login, con el rol que el
      // superadmin haya pre-asignado en padronPendiente (por defecto 'socio')
      allow create: if isOwner(uid)
        && exists(/databases/$(database)/documents/padronPendiente/$(emailToken()))
        && request.resource.data.email == emailToken()
        && request.resource.data.rol ==
             get(/databases/$(database)/documents/padronPendiente/$(emailToken()))
               .data.get('rolAsignado', 'socio');
      // Socio puede actualizar solo sus flags personales.
      // loginCount solo puede crecer de a 1 (estadística de uso no falseable).
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['ultimoLogin','onboardingOk','terminosAceptados','loginCount'])
        && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['loginCount'])
            || request.resource.data.loginCount == resource.data.get('loginCount', 0) + 1);
      allow delete: if false;
    }

    // Fichas pre-inscritas, a la espera del primer login (Google o Microsoft)
    match /padronPendiente/{email} {
      allow read, delete: if isDirectorio();
      // El directorio inscribe socios pero NO puede pre-asignar roles superiores
      allow create, update: if isDirectorio()
        && (!('rolAsignado' in request.resource.data)
            || request.resource.data.rolAsignado == 'socio');
      // Solo el superadmin pre-asigna rol directorio (prerrogativa de roles)
      allow create, update: if isSuperadmin()
        && (!('rolAsignado' in request.resource.data)
            || request.resource.data.rolAsignado in ['socio', 'directorio']);
      // El propio socio lee su ficha al reclamarla (eliminarla es solo del directorio)
      allow get: if isAuth() && emailToken() == email;
    }

    match /movimientos/{id} {
      allow read:  if isActivo();
      allow write: if isDirectorio();
    }

    match /votaciones/{id} {
      allow read:           if isActivo();
      allow create, delete: if isDirectorio();
      // Directorio gestiona la votación; socios solo pueden incrementar contadores en 'opciones'
      allow update: if isDirectorio()
        || (isActivo()
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['opciones']));
    }

    match /votantes/{votoId} {
      // Cada socio solo puede consultar SU voto (ID compuesto votacionId_uid)
      allow get:  if isDirectorio() || (isAuth() && votoId.matches('.*_' + request.auth.uid));
      allow list: if isDirectorio();
      allow create: if isActivo()
        && request.resource.data.uid == request.auth.uid
        && votoId == request.resource.data.votacionId + '_' + request.auth.uid;
      allow update, delete: if false;
    }

    match /poderes/{id} {
      allow read: if isDirectorio()
        || (isActivo() && resource.data.uid == request.auth.uid);
      allow create: if isActivo()
        && request.resource.data.uid == request.auth.uid;
      allow update: if (isActivo() && resource.data.uid == request.auth.uid)
        || isDirectorio();
      allow delete: if false;
    }

    match /actas/{id} {
      allow read: if isDirectorio()
        || (isActivo() && resource.data.publicada == true);
      allow write: if isDirectorio();
    }

    match /mensajes/{id} {
      allow read: if isDirectorio()
        || (isActivo() && resource.data.autorUid == request.auth.uid);
      // Sin suplantación: el nombre debe ser el de la ficha (o Anónimo/a),
      // los recordatorios automáticos solo los crea el directorio, y el
      // mensaje tiene largo acotado.
      allow create: if isActivo()
        && request.resource.data.autorUid == request.auth.uid
        && request.resource.data.mensaje is string
        && request.resource.data.mensaje.size() > 0
        && request.resource.data.mensaje.size() <= 3000
        && (
             (request.resource.data.get('esRecordatorio', false) == true && isDirectorio())
          || (request.resource.data.get('esRecordatorio', false) == false
              && request.resource.data.autorNombre ==
                   (request.resource.data.anonimo == true ? 'Anónimo/a' : userData().nombre))
        );
      allow update: if isDirectorio();
      allow delete: if false;
    }

    // Historial de pagos de cuotas por socio (ID determinístico uid_YYYY-MM)
    match /pagosCuotas/{pagoId} {
      // El socio consulta sus propios pagos; el directorio ve y gestiona todos
      allow get, list: if isDirectorio()
        || (isActivo() && resource.data.uid == request.auth.uid);
      allow create, update: if isDirectorio()
        && pagoId == request.resource.data.uid + '_' + request.resource.data.mes
        && request.resource.data.monto is int
        && request.resource.data.monto >= 0;
      allow delete: if isDirectorio();
    }

    match /notificaciones/{id} {
      allow read:  if isActivo();
      // Publicaciones con largo acotado (título 200, cuerpo 6000)
      allow create: if isDirectorio()
        && request.resource.data.titulo is string
        && request.resource.data.titulo.size() <= 200
        && request.resource.data.cuerpo is string
        && request.resource.data.cuerpo.size() <= 6000;
      allow update, delete: if isDirectorio();
    }

    // Mensajería in-app del directorio/superadmin hacia socios
    match /mensajesDirectorio/{id} {
      // El destinatario lee los suyos; el directorio lee todos
      allow read: if isDirectorio()
        || (isActivo() && resource.data.paraUid == request.auth.uid);
      // Solo directorio/superadmin envía, con largos acotados
      allow create: if isDirectorio()
        && request.resource.data.deUid == request.auth.uid
        && request.resource.data.asunto is string
        && request.resource.data.asunto.size() <= 200
        && request.resource.data.mensaje is string
        && request.resource.data.mensaje.size() <= 6000;
      // El destinatario solo puede marcar como leído
      allow update: if isActivo()
        && resource.data.paraUid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['leido']);
      allow delete: if isDirectorio();
    }

    match /eventos/{id} {
      allow read:  if isActivo();
      allow write: if isDirectorio();
    }

    match /beneficios/{id} {
      allow read:  if isActivo();
      allow write: if isDirectorio();
    }

    match /auditLog/{id} {
      allow read:   if isSuperadmin();
      // La identidad del registro debe salir del token (no falseable) y los
      // campos de texto tienen largo acotado.
      allow create: if isActivo()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.userEmail == request.auth.token.email
        && request.resource.data.keys().hasOnly(
             ['uid','userEmail','userNombre','accion','coleccion','documentoId','detalle','creadoEn'])
        && request.resource.data.accion is string
        && request.resource.data.accion.size() <= 64
        && (!('userNombre' in request.resource.data)
            || request.resource.data.userNombre == null
            || (request.resource.data.userNombre is string && request.resource.data.userNombre.size() <= 120))
        && (!('coleccion' in request.resource.data)
            || request.resource.data.coleccion == null
            || (request.resource.data.coleccion is string && request.resource.data.coleccion.size() <= 60));
      allow update, delete: if false;
    }

    match /config/{id} {
      allow read:  if isActivo();
      allow write: if isDirectorio();
    }
  }
}
